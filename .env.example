# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/caravanstallingspanje?sslmode=require

# Admin JWT secret (generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# Staff JWT secret
STAFF_JWT_SECRET=your-staff-jwt-secret-here

# Customer JWT secret
CUSTOMER_JWT_SECRET=your-customer-jwt-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@caravanstalling-spanje.com
SMTP_PASS=your-app-password
EMAIL_FROM=Caravanstalling Spanje <info@caravanstalling-spanje.com>

# Base URL
NEXT_PUBLIC_BASE_URL=https://caravanstalling-spanje.com

# Cron secret (for /api/cron/* endpoints — Vercel cron or admin manual trigger)
CRON_SECRET=your-cron-secret-here

# Resend API key (currently only via SMTP_*; set if using Resend SDK directly)
# RESEND_API_KEY=re_...
